{
  "kind": "collectionType",
  "collectionName": "galleries",
  "info": {
    "singularName": "gallery",
    "pluralName": "galleries",
    "displayName": "Galerie",
    "description": "Collection thematique / exposition regroupant des oeuvres (entite GALLERY du modele Merise)."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 160
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "year": {
      "type": "integer",
      "required": true,
      "min": 1900,
      "max": 2100
    },
    "month": {
      "type": "string",
      "maxLength": 20
    },
    "role": {
      "type": "string",
      "maxLength": 160
    },
    "place": {
      "type": "string",
      "maxLength": 160
    },
    "curator": {
      "type": "string",
      "maxLength": 160
    },
    "arts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::art.art",
      "mappedBy": "gallery"
    }
  }
}
