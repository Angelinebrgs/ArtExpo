{
  "kind": "collectionType",
  "collectionName": "arts",
  "info": {
    "singularName": "art",
    "pluralName": "arts",
    "displayName": "Oeuvre",
    "description": "Oeuvre individuelle (entite ARTWORK du modele Merise)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 160
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "year": {
      "type": "integer",
      "min": 1900,
      "max": 2100
    },
    "medium": {
      "type": "enumeration",
      "enum": [
        "performance",
        "cyanotype",
        "edition",
        "installation_sonore"
      ],
      "required": true
    },
    "img": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::gallery.gallery",
      "inversedBy": "arts"
    }
  }
}
